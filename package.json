{
  "name": "@z-guard/core",
  "version": "1.0.0",
  "description": "A standalone, neuro-symbolic hallucination mitigation and verification library for Agentic AI workflows.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agentic-ai",
    "hallucination",
    "mitigation",
    "llm",
    "guardrails",
    "nli",
    "zod",
    "verification"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.24",
    "express": "^4.19.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "zod": "^3.22.4"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1"
  }
}
